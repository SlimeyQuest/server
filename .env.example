# Application
APP_ENV=development
LOG_LEVEL=debug
SERVER_VERSION=dev

# HTTP listen address (host:port or :port)
HTTP_ADDR=:8080

# PostgreSQL
POSTGRES_DSN=postgres://postgres:postgres@localhost:5432/slimeyquest?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# WebSocket buffers
WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024

# Graceful shutdown
SHUTDOWN_TIMEOUT=10s
